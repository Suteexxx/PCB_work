# Copy this file to backend/.env and adjust as needed.
# All variables are optional -- sensible defaults are defined in app/core/config.py.
# Prefix is PCB_ for every setting (matches Settings.env_prefix).

# --- App ---
PCB_DEBUG=true

# --- Embedding model ---
# Any sentence-transformers model name works. all-MiniLM-L6-v2 is small/fast (~80MB).
# For higher quality at the cost of speed, try: all-mpnet-base-v2
PCB_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Web search agent ---
PCB_SEARCH_MAX_RESULTS=10
PCB_SCRAPE_MAX_CONCURRENT=6
PCB_SCRAPE_TIMEOUT_SECONDS=12.0

# --- Sentence ranking thresholds ---
# Lower = more (possibly less relevant) snippets kept. Raise this if results
# feel noisy; lower it if topics are returning too few snippets.
PCB_SIMILARITY_THRESHOLD=0.18

# --- Knowledge base ---
PCB_KB_CHUNK_SIZE_WORDS=180
PCB_KB_TOP_K=6

# --- Cache ---
PCB_CACHE_TTL_SECONDS=21600
